# Gemini — https://aistudio.google.com/apikey
# Server-only (used by /api/chat). Never expose to the browser.
# On Vercel: Project → Settings → Environment Variables → Production+Preview → Redeploy
# Health check: GET /api/health/ai
GOOGLE_GENERATIVE_AI_API_KEY=

# Auth.js / Google OAuth (kept in code; soft-disabled unless explicitly enabled)
# Set GOOGLE_AUTH_ENABLED=true AND credentials to turn Google sign-in back on.
GOOGLE_AUTH_ENABLED=false
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=

# Set true only for local/dev demo buttons
ALLOW_DEMO=false

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon JWT still works during migration; prefer publishable key above
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct Postgres (Settings → Database → Connection string → URI)
DATABASE_URL=

# Optional: server-side elevated access (Edge Functions / admin scripts only)
# SUPABASE_SECRET_KEY=
