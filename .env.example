# Gemini free tier — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Auth.js / Google OAuth
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=

# Set true only for local/dev demo buttons
ALLOW_DEMO=false

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon JWT still works during migration; prefer publishable key above
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct Postgres (Settings → Database → Connection string → URI)
DATABASE_URL=

# Optional: server-side elevated access (Edge Functions / admin scripts only)
# SUPABASE_SECRET_KEY=
