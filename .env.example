# Gemini — https://aistudio.google.com/apikey
# Server-only (used by /api/chat). Never expose to the browser.
# On Vercel: Project → Settings → Environment Variables → Production+Preview → Redeploy
# Health check: GET /api/health/ai
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: extra keys from OTHER Google Cloud projects (comma-separated). Same-project keys share quota.
# GOOGLE_GENERATIVE_AI_API_KEYS=
# Model id for new Google AI projects (default: gemini-flash-latest)
# GEMINI_MODEL=gemini-flash-latest

# Auth.js / Google OAuth — auto-enabled when credentials + AUTH_SECRET are set.
# Set GOOGLE_AUTH_ENABLED=false to force-disable Google sign-in.
GOOGLE_AUTH_ENABLED=
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=https://citov.tech

# Test login dialog (demo/admin users). Enabled by default; set false to disable.
ALLOW_TEST_LOGIN=true

# Set true only for local/dev demo buttons
ALLOW_DEMO=false

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon JWT still works during migration; prefer publishable key above
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct Postgres (Settings → Database → Connection string → URI)
# Optional in local dev: when unset, an in-memory store is used automatically.
DATABASE_URL=

# Optional: server-side elevated access (Edge Functions / admin scripts only)
# SUPABASE_SECRET_KEY=
